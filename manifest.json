{
  "manifest_version": 3,
  "name": "TD-东哥 Image Compress Ultra",
  "version": "1.0",
  "description": "TD-东哥出品：简约高效的图片上传自动压缩工具",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["ui.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
